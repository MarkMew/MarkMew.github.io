---
layout: null
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for post in site.posts %}
  {% assign post_lang = post.lang | default: site.default_lang %}
  {% if post_lang == site.default_lang %}
    {% assign post_url = post.url | remove: 'index.html' %}
  {% else %}
    {% assign post_url = '/' | append: post_lang | append: post.url | remove: 'index.html' %}
  {% endif %}
  <url>
    <loc>{{ site.url }}{{ post_url }}</loc>
    {% if post.last_modified_at %}<lastmod>{{ post.last_modified_at | date_to_xmlschema }}</lastmod>
    {% elsif post.date %}<lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    {% endif %}
  </url>
  {% endfor %}
  {% for page in site.pages %}
  {% unless page.sitemap == false or page.url contains 'sitemap' or page.url contains 'feed' or page.url contains '404' %}
  {% assign page_lang = page.lang | default: site.default_lang %}
  {% if page_lang == site.default_lang %}
    {% assign page_url = page.url | remove: 'index.html' %}
  {% else %}
    {% assign page_url = '/' | append: page_lang | append: page.url | remove: 'index.html' %}
  {% endif %}
  <url>
    <loc>{{ site.url }}{{ page_url }}</loc>
    {% if page.last_modified_at %}<lastmod>{{ page.last_modified_at | date_to_xmlschema }}</lastmod>{% endif %}
  </url>
  {% endunless %}
  {% endfor %}
</urlset>
